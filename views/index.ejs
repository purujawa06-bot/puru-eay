<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Puru AI - ChatGPT Clone</title>
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: #2d3748;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #4a5568;
            border-radius: 10px;
        }
        .htmx-indicator {
            display: none;
        }
        .htmx-request .htmx-indicator {
            display: flex;
        }
        .htmx-request.htmx-indicator {
            display: flex;
        }
        @keyframes shimmer {
            0% { background-position: -200% 0; }
            100% { background-position: 200% 0; }
        }
        .shimmer {
            background: linear-gradient(90deg, #374151 25%, #4b5563 50%, #374151 75%);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
        }
    </style>
</head>
<body class="bg-[#343541] text-white h-screen flex overflow-hidden">

    <!-- Sidebar -->
    <div class="w-64 bg-[#202123] h-full flex flex-col p-2 hidden md:flex">
        <button class="border border-white/20 rounded-md p-3 text-sm flex items-center gap-3 hover:bg-gray-500/10 transition-colors mb-2">
            <svg stroke="currentColor" fill="none" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" xmlns="http://www.w3.org/2000/svg"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            New Chat
        </button>
        <button id="clear-chat" class="border border-white/20 rounded-md p-3 text-sm flex items-center gap-3 hover:bg-red-500/10 hover:text-red-400 hover:border-red-500/50 transition-colors mb-2">
            <svg stroke="currentColor" fill="none" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" xmlns="http://www.w3.org/2000/svg"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
            Clear Chat
        </button>
        <div class="flex-grow"></div>
        <div class="border-t border-white/20 pt-2">
            <div class="p-3 text-sm hover:bg-gray-500/10 rounded-md cursor-pointer">Upgrade to Plus</div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="flex-grow flex flex-col h-full relative">
        <!-- Header -->
        <header class="p-4 border-b border-white/10 text-center font-semibold text-gray-300">
            Puru AI (puruboy-flash)
        </header>

        <!-- Chat Container -->
        <div id="chat-box" class="flex-grow overflow-y-auto p-4 md:px-20 custom-scrollbar">
            <div class="flex flex-col mb-4 items-start">
                <div class="bg-gray-700 text-gray-100 rounded-lg py-2 px-4 max-w-[80%]">
                    Halo! Saya Puru AI. Ada yang bisa saya bantu hari ini?
                </div>
            </div>
            
            <!-- Loading Indicator -->
            <div id="loading-indicator" class="htmx-indicator flex flex-col mb-4 items-start w-full">
                <div class="bg-gray-700/50 border border-white/5 rounded-lg p-4 w-[70%] space-y-3">
                    <div class="flex items-center gap-2 mb-2">
                        <div class="flex gap-1">
                            <div class="w-1.5 h-1.5 bg-blue-400 rounded-full animate-bounce [animation-delay:-0.3s]"></div>
                            <div class="w-1.5 h-1.5 bg-blue-400 rounded-full animate-bounce [animation-delay:-0.15s]"></div>
                            <div class="w-1.5 h-1.5 bg-blue-400 rounded-full animate-bounce"></div>
                        </div>
                        <span class="text-[10px] uppercase tracking-wider font-bold text-blue-400/80">Puru AI is typing</span>
                    </div>
                    <div class="shimmer h-3 w-full rounded-full opacity-30"></div>
                    <div class="shimmer h-3 w-[90%] rounded-full opacity-30"></div>
                    <div class="shimmer h-3 w-[40%] rounded-full opacity-30"></div>
                </div>
            </div>
        </div>

        <!-- Input Area -->
        <div class="p-4 md:px-20 border-t border-white/10 bg-[#343541]">
            <form hx-post="/chat" 
                  hx-target="#loading-indicator" 
                  hx-swap="beforebegin" 
                  hx-indicator="#loading-indicator"
                  hx-on::after-request="this.reset()"
                  class="relative flex items-center">
                <input type="text" 
                       name="prompt" 
                       placeholder="Send a message..." 
                       class="w-full bg-[#40414f] text-white rounded-xl py-3 px-4 pr-12 focus:outline-none focus:ring-1 focus:ring-white/20 shadow-lg"
                       required>
                <button type="submit" class="absolute right-3 p-1 rounded-md text-gray-400 hover:bg-gray-900 transition-colors">
                    <svg stroke="currentColor" fill="none" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" xmlns="http://www.w3.org/2000/svg"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                </button>
            </form>
            <p class="text-[10px] text-gray-400 text-center mt-2">
                Puru AI may provide inaccurate information. Check important info.
            </p>
        </div>
    </div>

    <script>
        const chatBox = document.getElementById('chat-box');
        const clearChatBtn = document.getElementById('clear-chat');
        const STORAGE_KEY = 'chat_history_v1';

        // Initial welcome message template
        const welcomeMessage = `
            <div class="flex flex-col mb-4 items-start">
                <div class="bg-gray-700 text-gray-100 rounded-lg py-2 px-4 max-w-[80%]">
                    Halo! Saya Puru AI. Ada yang bisa saya bantu hari ini?
                </div>
            </div>
        `;

        // Function to save chat history
        const saveChatHistory = () => {
            try {
                const messages = Array.from(chatBox.children)
                    .filter(child => child.id !== 'loading-indicator')
                    .map(child => child.outerHTML)
                    .join('');
                localStorage.setItem(STORAGE_KEY, JSON.stringify(messages));
            } catch (err) {
                console.error('Error saving to localStorage:', err);
            }
        };

        // Function to load chat history
        const loadChatHistory = () => {
            try {
                const savedData = localStorage.getItem(STORAGE_KEY);
                if (savedData) {
                    const messagesHtml = JSON.parse(savedData);
                    const indicator = document.getElementById('loading-indicator');
                    
                    // Create a temporary container to hold the HTML
                    const tempDiv = document.createElement('div');
                    tempDiv.innerHTML = messagesHtml;
                    
                    // Clear current box and append saved messages then indicator
                    chatBox.innerHTML = '';
                    while (tempDiv.firstChild) {
                        chatBox.appendChild(tempDiv.firstChild);
                    }
                    chatBox.appendChild(indicator);
                }
            } catch (err) {
                console.error('Error loading from localStorage:', err);
                localStorage.removeItem(STORAGE_KEY); // Clear corrupted data
            }
        };

        // MutationObserver to handle auto-scroll and auto-save
        const observer = new MutationObserver(() => {
            chatBox.scrollTop = chatBox.scrollHeight;
            saveChatHistory();
        });

        observer.observe(chatBox, { childList: true });

        // Clear chat functionality
        clearChatBtn.addEventListener('click', () => {
            if (confirm('Are you sure you want to clear the entire chat history?')) {
                localStorage.removeItem(STORAGE_KEY);
                const indicator = document.getElementById('loading-indicator').cloneNode(true);
                chatBox.innerHTML = welcomeMessage;
                chatBox.appendChild(indicator);
            }
        });

        // Initialize
        window.addEventListener('load', loadChatHistory);
    </script>
</body>
</html>